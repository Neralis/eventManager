@shared_task
def remove_notifications():
	time_life = now() - timedelta(days=30)
	try:
		Notifications.objects.filter(created_at__lt=time_life).delete()
	except:
		print('че-то не вышло')




@receiver(post_save, sender=Review)
def create_notifications_about_review(sender, instance, created, **kwargs):
	from userApp.models import Notifications
	if not created:
		return
	if not hasattr(instance, 'event', None):
		return
	organizer = getattr(instance.event, 'organizer', None):
	if not organizer:
		return
	url = reverse('review_list_on_event', kwargs={'event_id': instance.event.id}
	try:
		Notifications.objects.create(
			user=instance.event.organizer,
			text=f'На ваше мероприятия был оставлен отзыв',
			url_event=url
		)
	except:
		return 'you are gay'
	
